generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  passwordHash            String
  passwordResetTokenHash  String?
  passwordResetExpiresAt  DateTime?
  passwordChangedAt       DateTime?
  tokenVersion            Int                      @default(0)
  role                    Role
  subCounty               String?
  isActive                Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  farmers                 Farmer[]
  inspections             Inspection[]
  auditLogs               AuditLog[]
  queries                 Query[]
  captureFisheriesRecords CaptureFisheriesRecord[]
  cageProductionRecords   CageProductionRecord[]

  @@index([role])
  @@index([subCounty])
  @@index([passwordResetTokenHash])
}

enum Role {
  DIRECTOR
  FISHERIES_OFFICER
  DATA_ANALYST
  FARMER
  ADMIN
}

model Farmer {
  id                String             @id @default(cuid())
  farmerCode        String             @unique @default(dbgenerated("('MIF-FRM-'::text || lpad((nextval('\"Farmer_farmerCode_seq\"'::regclass))::text, 6, '0'::text))"))
  name              String
  idNumber          String?
  phoneNumber       String?
  email             String?
  gender            Gender?
  ageBracket        AgeBracket?
  subCounty         String
  ward              String             @default("Unspecified")
  farmType          FarmType
  species           String[]
  licenseNo         String?
  status            FarmerStatus       @default(ACTIVE)
  productionKg      Float              @default(0)
  numberOfPonds     Int                @default(0)
  activePonds       Int                @default(0)
  inactivePonds     Int                @default(0)
  latitude          Float?
  longitude         Float?
  registeredById    String
  registeredBy      User               @relation(fields: [registeredById], references: [id])
  licenses          License[]
  productionRecords ProductionRecord[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([subCounty])
  @@index([status])
}

enum FarmType {
  POND
  CAGE
  TANK
  DAM
}

enum FarmerStatus {
  ACTIVE
  INACTIVE
  PARTIALLY_ACTIVE
  SUSPENDED
}

model License {
  id                String        @id @default(cuid())
  licenseNo         String        @unique
  receiptNo         String?       @unique
  bmuName           String?
  holderName        String?
  holderIdNumber    String?
  holderPhoneNumber String?
  holderEmail       String?
  subCounty         String?
  ward              String?
  beachName         String?
  market            String?
  amountLicensed    Float         @default(0)
  licensedById      String?
  licensedByName    String?
  farmerId          String?
  farmer            Farmer?       @relation(fields: [farmerId], references: [id])
  type              LicenseType
  issuedDate        DateTime
  expiryDate        DateTime
  status            LicenseStatus @default(PENDING)
  approvedById      String?
  approvedAt        DateTime?
  createdAt         DateTime      @default(now())

  @@index([farmerId])
  @@index([status])
}

enum LicenseType {
  FISH_DEPOT
  FISHERMAN
  FISH_TRADER
  BOAT_OWNER
  FISH_MOVEMENT_PERMIT
  BOAT_LICENSE
  NEW_BOARD_REGISTRATION
  ICE_PLANT
  BOAT
}

enum LicenseStatus {
  PENDING
  VALID
  EXPIRED
  REVOKED
  REJECTED
}

model ProductionRecord {
  id        String   @id @default(cuid())
  farmerId  String
  farmer    Farmer   @relation(fields: [farmerId], references: [id])
  species   String
  volumeKg  Float
  season    String
  year      Int
  month     Int
  createdAt DateTime @default(now())

  @@index([farmerId])
  @@index([year, month])
}

model CaptureFisheriesRecord {
  id                    String                @id @default(cuid())
  captureCode           String                @unique @default(dbgenerated("('MIF-CAP-'::text || lpad((nextval('\"CaptureFisheriesRecord_captureCode_seq\"'::regclass))::text, 6, '0'::text))"))
  extensionOfficerName  String
  extensionOfficerPhone String
  fisherName            String
  farmerNumber          String?
  idNumber              String?
  phoneNumber           String?
  gender                Gender
  ageBracket            AgeBracket
  topics                String[]              @default([])
  bmuName               String?
  landingSite           String?
  activeCages           Int                   @default(0)
  inactiveCages         Int                   @default(0)
  ward                  String                @default("Unspecified")
  latitude              Float?
  longitude             Float?
  species               String
  catchKg               Float
  value                 Float                 @default(0)
  effortHours           Float?
  approvalStatus        CaptureApprovalStatus @default(PENDING)
  approvedById          String?
  approvedAt            DateTime?
  fishingDate           DateTime
  month                 Int?
  year                  Int?
  subCounty             String                @default("Nyatike")
  recordedById          String
  recordedBy            User                  @relation(fields: [recordedById], references: [id])
  createdAt             DateTime              @default(now())

  @@index([subCounty])
  @@index([fishingDate])
  @@index([recordedById])
  @@index([approvalStatus])
}

model CageProductionRecord {
  id                    String    @id @default(cuid())
  cageCode              String    @unique @default(dbgenerated("('MIF-CAGE-'::text || lpad((nextval('\"CageProductionRecord_cageCode_seq\"'::regclass))::text, 6, '0'::text))"))
  farmerUniqueId        String
  farmerName            String
  phoneNumber           String?
  idNumber              String?
  bmuLocation           String?
  cageIdentifier        String?
  fishSpecies           String    @default("Tilapia")
  subCounty             String
  ward                  String
  numberOfCages         Int       @default(0)
  activeCages           Int       @default(0)
  inactiveCages         Int       @default(0)
  fingerlingsStocked    Int       @default(0)
  stockingDate          DateTime?
  feedTypes             String[]  @default([])
  feedQuantityKg        Float     @default(0)
  averageFishWeightKg   Float     @default(0)
  mortalityPieces       Int       @default(0)
  quantityHarvestedKg   Float     @default(0)
  numberHarvestedPieces Int       @default(0)
  harvestDate           DateTime?
  extensionOfficerName  String?
  remarks               String?
  month                 Int
  year                  Int
  recordedById          String
  recordedBy            User      @relation(fields: [recordedById], references: [id])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([subCounty])
  @@index([year, month])
  @@index([recordedById])
}

enum Gender {
  MALE
  FEMALE
}

enum AgeBracket {
  YOUTH
  ADULT
}

enum CaptureApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Inspection {
  id                    String           @id @default(cuid())
  farmName              String
  extensionOfficerName  String?
  extensionOfficerPhone String?
  subCounty             String
  ward                  String           @default("Unspecified")
  farmerPhoneNumber     String?
  extensionTopics       String[]         @default([])
  feedback              String?
  challenges            String?
  officerId             String
  officer               User             @relation(fields: [officerId], references: [id])
  date                  DateTime
  result                InspectionResult
  notes                 String?
  createdAt             DateTime         @default(now())

  @@index([subCounty])
  @@index([officerId])
}

enum InspectionResult {
  PASS
  FAIL
  PENDING
}

model BlueEconomyProject {
  id                     String          @id @default(cuid())
  projectCode            String          @unique @default(dbgenerated("('MIF-PRJ-'::text || lpad((nextval('\"BlueEconomyProject_projectCode_seq\"'::regclass))::text, 6, '0'::text))"))
  budgetLine             String?
  category               ProjectCategory @default(BLUE_ECONOMY)
  name                   String
  description            String          @default("")
  subCounty              String
  ward                   String          @default("Unspecified")
  latitude               Float?
  longitude              Float?
  budget                 Float
  completionPercent      Float           @default(0)
  funder                 String
  status                 ProjectStatus   @default(PLANNED)
  photos                 String[]        @default([])
  responsibleOfficerId   String?
  responsibleOfficerName String?
  startDate              DateTime
  endDate                DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@index([subCounty])
  @@index([status])
  @@index([budgetLine])
}

enum ProjectCategory {
  BLUE_ECONOMY
  LAKEFRONT_DEVELOPMENT
  AQUACULTURE_DEVELOPMENT
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  STALLED
  PLANNED
  ONGOING
  COMPLETED
  CANCELLED
}

model Advisory {
  id           String       @id @default(cuid())
  title        String
  message      String
  type         AdvisoryType
  fromName     String
  subCounty    String?
  targetUserId String?
  createdAt    DateTime     @default(now())

  @@index([subCounty])
  @@index([targetUserId])
}

enum AdvisoryType {
  INFO
  WARNING
  ACTION
}

model Query {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  subject     String
  message     String
  status      QueryStatus @default(PENDING)
  reply       String?
  replyById   String?
  replyByName String?
  repliedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([replyById])
}

enum QueryStatus {
  PENDING
  RESOLVED
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  resource  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resource])
}
