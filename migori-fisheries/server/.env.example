# Runtime
NODE_ENV=production
PORT=4000

# Frontend origins (for CORS)
FRONTEND_ORIGIN=https://your-frontend-domain.vercel.app
FRONTEND_ORIGINS=https://your-frontend-domain.vercel.app,https://preview-frontend-domain.vercel.app

# Database (Supabase Postgres)
DATABASE_URL=postgresql://postgres.<project-ref>:<PASSWORD>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Auth secrets
JWT_ACCESS_SECRET=replace_with_a_base64_or_random_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_with_a_random_secret_32_chars_minimum

# Cookie/session settings
COOKIE_SAME_SITE=none
COOKIE_DOMAIN=

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx
