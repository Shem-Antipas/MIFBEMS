NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173

# Local PostgreSQL:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mifbems
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/mifbems

# Supabase Prisma setup:
# Get these from Supabase Dashboard > Connect > ORMs > Prisma.
# Use the Session pooler URL for DATABASE_URL and DIRECT_URL when running from local Windows/IPv4.
# Format:
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require
# DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres?sslmode=require

JWT_ACCESS_SECRET=replace_with_minimum_32_characters_access_secret
JWT_REFRESH_SECRET=replace_with_minimum_32_characters_refresh_secret
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
